# Service Worker darf nie gecacht werden, sonst bemerken Browser
# Updates an sw.js (und damit an app.js etc.) nicht zuverlässig.
<IfModule mod_headers.c>
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
